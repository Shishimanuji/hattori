import React from 'react'
import { render, screen, fireEvent, waitFor } from '@testing-library/react'
import { QueryClient, QueryClientProvider } from '@tanstack/react-query'
import { ResourceList } from './ResourceList'
import * as resourceService from '../../services/resources'
import { vi, describe, it, expect, beforeEach } from 'vitest'

// Mock the resource service
vi.mock('../../services/resources', () => ({
  resourceService: {
    getResources: vi.fn(),
    deleteResource: vi.fn(),
  },
}))

describe('ResourceList Component', () => {
  let queryClient: QueryClient

  beforeEach(() => {
    queryClient = new QueryClient({
      defaultOptions: {
        queries: { retry: false },
        mutations: { retry: false },
      },
    })
    vi.clearAllMocks()
  })

  const mockResources = [
    {
      id: 'res-1',
      project_id: 'proj-1',
      asset_type_id: 'at-1',
      name: 'Resource 1',
      cost: 1000,
      allocation_date: '2024-01-15',
      status: 'Active',
      custom_fields: {},
      created_by: 'user-1',
      created_at: '2024-01-15T10:00:00Z',
      updated_at: '2024-01-15T10:00:00Z',
    },
    {
      id: 'res-2',
      project_id: 'proj-1',
      asset_type_id: 'at-1',
      name: 'Resource 2',
      cost: 2000,
      allocation_date: '2024-01-20',
      status: 'Inactive',
      custom_fields: {},
      created_by: 'user-1',
      created_at: '2024-01-20T10:00:00Z',
      updated_at: '2024-01-20T10:00:00Z',
    },
  ]

  it('should render resource list with data', async () => {
    const getResourcesSpy = vi.spyOn(resourceService, 'getResources' as any)
    getResourcesSpy.mockResolvedValue({
      data: mockResources,
      total: 2,
      page: 1,
      limit: 10,
    })

    const onEdit = vi.fn()
    const onDelete = vi.fn()

    render(
      <QueryClientProvider client={queryClient}>
        <ResourceList
          projectId="proj-1"
          onEdit={onEdit}
          onDelete={onDelete}
        />
      </QueryClientProvider>
    )

    await waitFor(() => {
      expect(screen.getByText('Resource 1')).toBeInTheDocument()
      expect(screen.getByText('Resource 2')).toBeInTheDocument()
    })
  })

  it('should filter resources by search term', async () => {
    const getResourcesSpy = vi.spyOn(resourceService, 'getResources' as any)
    getResourcesSpy.mockResolvedValue({
      data: mockResources,
      total: 2,
      page: 1,
      limit: 10,
    })

    const onEdit = vi.fn()

    render(
      <QueryClientProvider client={queryClient}>
        <ResourceList projectId="proj-1" onEdit={onEdit} />
      </QueryClientProvider>
    )

    await waitFor(() => {
      expect(screen.getByText('Resource 1')).toBeInTheDocument()
    })

    const searchInput = screen.getByPlaceholderText('Search by name...')
    fireEvent.change(searchInput, { target: { value: 'Resource 1' } })

    // Local filtering should work
    expect(searchInput).toHaveValue('Resource 1')
  })

  it('should display status badges correctly', async () => {
    const getResourcesSpy = vi.spyOn(resourceService, 'getResources' as any)
    getResourcesSpy.mockResolvedValue({
      data: mockResources,
      total: 2,
      page: 1,
      limit: 10,
    })

    const onEdit = vi.fn()

    render(
      <QueryClientProvider client={queryClient}>
        <ResourceList projectId="proj-1" onEdit={onEdit} />
      </QueryClientProvider>
    )

    await waitFor(() => {
      expect(screen.getByText('Active')).toBeInTheDocument()
      expect(screen.getByText('Inactive')).toBeInTheDocument()
    })
  })

  it('should call onEdit when edit button is clicked', async () => {
    const getResourcesSpy = vi.spyOn(resourceService, 'getResources' as any)
    getResourcesSpy.mockResolvedValue({
      data: mockResources,
      total: 2,
      page: 1,
      limit: 10,
    })

    const onEdit = vi.fn()

    render(
      <QueryClientProvider client={queryClient}>
        <ResourceList projectId="proj-1" onEdit={onEdit} />
      </QueryClientProvider>
    )

    await waitFor(() => {
      expect(screen.getByText('Resource 1')).toBeInTheDocument()
    })

    const editButtons = screen.getAllByLabelText(/Edit/i)
    fireEvent.click(editButtons[0])

    expect(onEdit).toHaveBeenCalledWith('res-1')
  })

  it('should call onDelete when delete button is clicked', async () => {
    const getResourcesSpy = vi.spyOn(resourceService, 'getResources' as any)
    getResourcesSpy.mockResolvedValue({
      data: mockResources,
      total: 2,
      page: 1,
      limit: 10,
    })

    const onDelete = vi.fn()

    render(
      <QueryClientProvider client={queryClient}>
        <ResourceList projectId="proj-1" onEdit={vi.fn()} onDelete={onDelete} />
      </QueryClientProvider>
    )

    await waitFor(() => {
      expect(screen.getByText('Resource 1')).toBeInTheDocument()
    })

    const deleteButtons = screen.getAllByLabelText(/Delete/i)
    fireEvent.click(deleteButtons[0])

    // Should show confirmation dialog
    await waitFor(() => {
      expect(screen.getByText(/Are you sure/i)).toBeInTheDocument()
    })

    const confirmButton = screen.getByRole('button', { name: /Delete/i })
    fireEvent.click(confirmButton)

    await waitFor(() => {
      expect(onDelete).toHaveBeenCalledWith('res-1')
    })
  })

  it('should display empty state when no resources', async () => {
    const getResourcesSpy = vi.spyOn(resourceService, 'getResources' as any)
    getResourcesSpy.mockResolvedValue({
      data: [],
      total: 0,
      page: 1,
      limit: 10,
    })

    const onEdit = vi.fn()

    render(
      <QueryClientProvider client={queryClient}>
        <ResourceList projectId="proj-1" onEdit={onEdit} />
      </QueryClientProvider>
    )

    await waitFor(() => {
      expect(screen.getByText('No resources available')).toBeInTheDocument()
    })
  })
})
